{
  "entities": {
    "BlogPost": {
      "title": "BlogPost",
      "description": "A single blog post in the portfolio",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the blog post" },
        "content": { "type": "string", "description": "Markdown content of the post" },
        "category": { "type": "string", "enum": ["개발일지", "일상", "작품감상평"], "description": "Category of the blog post" },
        "createdAt": { "type": "integer", "description": "Timestamp in milliseconds" },
        "imageUrl": { "type": "string", "description": "Optional image URL" },
        "tags": { "type": "array", "description": "Optional tags" }
      },
      "required": ["title", "content", "category", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A single project showcase item",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the project" },
        "description": { "type": "string", "description": "Short summary" },
        "content": { "type": "string", "description": "Detailed project description in markdown" },
        "techStack": { "type": "array", "description": "List of technologies used" },
        "role": { "type": "string", "description": "Role in the project" },
        "period": { "type": "string", "description": "Duration/period of development" },
        "imageUrl": { "type": "string", "description": "Optional image URL" },
        "githubUrl": { "type": "string", "description": "Optional GitHub link" },
        "liveUrl": { "type": "string", "description": "Optional live preview link" },
        "createdAt": { "type": "integer", "description": "Timestamp in milliseconds" }
      },
      "required": ["title", "description", "content", "techStack", "role", "period", "createdAt"]
    },
    "Profile": {
      "title": "Profile",
      "description": "Admin developer profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Developer's name" },
        "title": { "type": "string", "description": "Professional subtitle/role" },
        "bio": { "type": "string", "description": "Longer self-introduction" },
        "imageUrl": { "type": "string", "description": "Optional URL for profile photo" },
        "githubUrl": { "type": "string", "description": "Optional GitHub profile link" },
        "email": { "type": "string", "description": "Optional contact email" }
      },
      "required": ["name", "title", "bio"]
    }
  },
  "firestore": {
    "blogs/{blogId}": {
      "schema": "BlogPost",
      "description": "Collection of blog posts"
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of project items"
    },
    "profile/{profileId}": {
      "schema": "Profile",
      "description": "Collection storing the developer profile"
    }
  }
}
