rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net - Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'S6PiqtX8z8Uhved6rkncAEMDhZp1' ||
        request.auth.token.email == 'heoha78@gmail.com' ||
        request.auth.token.email == 'Heoha78@gmail.com' ||
        request.auth.token.email == 'macaron010@naver.com' ||
        request.auth.token.email == 'Macaron010@naver.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Validation Blueprints
    function isValidBlogPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.content is string && data.content.size() <= 50000
        && data.category is string && (data.category == '개발일지' || data.category == '일상' || data.category == '작품감상평')
        && data.createdAt is int && data.createdAt > 0
        && ( !('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2000) )
        && ( !('tags' in data) || (data.tags is list && data.tags.size() <= 20) )
        && data.keys().hasAll(['title', 'content', 'category', 'createdAt'])
        && data.keys().size() <= 6;
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() <= 1000
        && data.content is string && data.content.size() <= 50000
        && data.techStack is list && data.techStack.size() <= 50
        && data.role is string && data.role.size() <= 200
        && data.period is string && data.period.size() <= 100
        && data.createdAt is int && data.createdAt > 0
        && ( !('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2000) )
        && ( !('githubUrl' in data) || (data.githubUrl is string && data.githubUrl.size() <= 2000) )
        && ( !('liveUrl' in data) || (data.liveUrl is string && data.liveUrl.size() <= 2000) )
        && ( !('participants' in data) || (data.participants is list && data.participants.size() <= 50) )
        && data.keys().hasAll(['title', 'description', 'content', 'techStack', 'role', 'period', 'createdAt'])
        && data.keys().size() <= 12;
    }

    function isValidProfile(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.title is string && data.title.size() <= 200
        && data.bio is string && data.bio.size() <= 2000
        && ( !('imageUrl' in data) || data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 2000) )
        && ( !('githubUrl' in data) || data.githubUrl == null || (data.githubUrl is string && data.githubUrl.size() <= 2000) )
        && ( !('email' in data) || data.email == null || (data.email is string && data.email.size() <= 320) )
        && ( !('instagramUrl' in data) || data.instagramUrl == null || (data.instagramUrl is string && data.instagramUrl.size() <= 2000) )
        && ( !('customUrl' in data) || data.customUrl == null || (data.customUrl is string && data.customUrl.size() <= 2000) )
        && data.keys().hasAll(['name', 'title', 'bio'])
        && data.keys().size() <= 12;
    }

    // 4. Match Blocks for Collections
    match /blogs/{blogId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(blogId) && isValidBlogPost(incoming());
      allow update: if isAdmin() && isValidId(blogId) && isValidBlogPost(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(blogId);
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isAdmin() && isValidId(projectId) && isValidProject(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(projectId);
    }

    match /profile/{profileId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(profileId) && isValidProfile(incoming());
      allow delete: if isAdmin() && isValidId(profileId);
    }

    match /gallery/{galleryId} {
      allow read: if true;
      allow create, delete: if isAdmin() && isValidId(galleryId);
      allow update: if isValidId(galleryId);
    }

    match /playlist_tracks/{trackId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(trackId);
    }

    match /milestones/{milestoneId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(settingId);
    }
  }
}
